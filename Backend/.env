ENV=production
MONGO_URL=mongodb://localhost:27017/
DB_NAME=campus_security

SECRET_KEY=replace_with_long_random_secret_64_plus_chars

MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your_email@example.com
SMTP_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Campus Guard AI
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

WAHA_API_URL=http://localhost:3000
WAHA_API_KEY=replace_with_waha_api_key
WAHA_SESSION=default
WAHA_TIMEOUT_SEC=10
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=replace_with_hashed_password
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=replace_with_hashed_password
GUARD_NOT_FOUND_REPLY_COOLDOWN_SEC=0

ENABLE_OTP_PREVIEW=False

GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_SEC=20